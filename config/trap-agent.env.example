# คัดลอกเป็น /etc/longan-fruit-fly/trap-agent.env หรือ .env บนเครื่องทดสอบ
TRAP_ID=A1
TRAP_NAME=กับดัก A1
TRAP_LOCATION=สวนลำไย อำเภอซับใหญ่ จังหวัดชัยภูมิ
API_URL=http://localhost:3000/api/readings
TRAP_API_TOKEN=change-me
CAMERA_INDEX=0
CAPTURE_INTERVAL_SECONDS=1800
IMAGE_DIR=/var/lib/longan-fruit-fly/images
MIN_COMPONENT_AREA=12
MAX_COMPONENT_RATIO=0.05
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_THRESHOLD=25
